{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "make -j$(nproc)",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "run",
            "type": "shell",
            "command": "./build/Debug/hexapod",
            "group": "test",
            "dependsOn": "build"
        }
    ]
}
